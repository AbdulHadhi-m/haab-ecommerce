# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/haab-ecommerce?retryWrites=true&w=majority

# CORS
CORS_ORIGIN=http://localhost:3000

# JWT Access Token
JWT_ACCESS_SECRET=
ACCESS_TOKEN_EXPIRES=15m

# JWT Refresh Token
JWT_REFRESH_SECRET=
REFRESH_TOKEN_EXPIRES=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
