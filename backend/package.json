{
  "name": "@haab/backend",
  "version": "0.1.0",
  "private": true,
  "description": "HAAB ecommerce backend API",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/database/seed.ts",
    "test": "jest --passWithNoTests --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.12.1",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "nodemailer": "^6.10.1",
    "razorpay": "^2.9.6",
    "streamifier": "^0.1.1",
    "stripe": "^17.7.0",
    "xss-clean": "^0.1.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.24",
    "@types/streamifier": "^0.1.2",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.23.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.4.0",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0"
  }
}
